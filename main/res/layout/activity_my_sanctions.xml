<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MySanctions">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/nametoolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0091EA"
        app:title="이용 제한 내역"
        tools:ignore="MissingConstraints" />
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="10dp"
        android:background="@drawable/edge">
        <TextView
            android:id="@+id/limit1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="제한 안내"
            android:textSize="20sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="10dp"
            android:layout_alignParentRight="true"
            android:gravity="right"
            android:text="04/30 19:18" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/limit1"
            android:text="[접근 제한 안내]신고가 누적되어 자동 신고 처리 시스템에 의해 접근 제한 조치되었습니다.\n
접근제한 목록 : 댓글"
            />
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="10dp"
        android:background="@drawable/edge">
        <TextView
            android:id="@+id/limit2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="제한 안내"
            android:textSize="20sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="10dp"
            android:layout_alignParentRight="true"
            android:gravity="right"
            android:text="04/30 19:18" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/limit2"
            android:text="[접근 제한 안내]신고가 누적되어 자동 신고 처리 시스템에 의해 접근 제한 조치되었습니다.\n
접근제한 목록 : 비밀 게시판"
            />
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="10dp"
        android:background="@drawable/edge">
        <TextView
            android:id="@+id/limit3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="제한 안내"
            android:textSize="20sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="10dp"
            android:layout_alignParentRight="true"
            android:gravity="right"
            android:text="03/30 12:13" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/limit3"
            android:text="[접근 제한 안내]신고가 누적되어 자동 신고 처리 시스템에 의해 접근 제한 조치되었습니다.\n
접근제한 목록 : 전체 게시판"
            />
    </RelativeLayout>


</LinearLayout>